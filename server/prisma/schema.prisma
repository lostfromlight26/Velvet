generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RecentSong {
  id         Int      @id @default(autoincrement())
  youtubeId  String   @unique
  title      String
  artist     String
  thumbnail  String
  duration   String
  playedAt   DateTime @updatedAt
}